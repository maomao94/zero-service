syntax = "v1"

import "doc/base.api"
import "doc/openai_types.api"

info (
	title:   "AI网关服务"
	desc:    "OpenAI 兼容 AI 网关"
	author:  "hehanpeng"
	email:   "hehanpengyy@163.com"
	version: "v1"
)

// pass 组 - 普通接口（模型列表）
@server (
	prefix: ai/v1
	group:  pass
)
service aigtw {
	@doc "列出可用模型"
	@handler listModels
	get /models returns (ListModelsResponse)
}

// pass 组 - SSE 流式接口
@server (
	prefix:  ai/v1
	group:   pass
	timeout: 0s
	sse:     true
)
service aigtw {
	@doc "对话补全"
	@handler chatCompletions
	post /chat/completions (ChatCompletionRequest) returns (ChatCompletionResponse)
}

