syntax = "v1"

import "doc/base.api"
import "doc/openai_types.api"

info (
	title:   "AI网关服务"
	desc:    "OpenAI 兼容 AI 网关，提供对话补全、模型列表、异步工具调用等功能"
	author:  "hehanpeng"
	email:   "hehanpengyy@163.com"
	version: "v1"
)

// ============================================================
// pass 组 - 模型列表接口
// ============================================================
// 模型列表
// - 前缀: /ai/v1
// - 认证: JWT
// - 超时: 默认（无特殊限制）
@server (
	prefix: ai/v1
	group:  pass
	jwt:    JwtAuth
)
service aigtw {
	@doc "列出所有可用模型"
	@handler listModels
	get /models returns (ListModelsResponse)
}

// ============================================================
// pass 组 - SSE 流式接口
// ============================================================
// 对话补全（流式）
// - 前缀: /ai/v1
// - 认证: JWT
// - 超时: 0s（无超时限制，支持长对话）
// - SSE: true（启用 Server-Sent Events 流式响应）
@server (
	prefix:  ai/v1
	group:   pass
	jwt:     JwtAuth
	timeout: 0s
	sse:     true
)
service aigtw {
	@doc "对话补全"
	@handler chatCompletions
	post /chat/completions (ChatCompletionRequest) returns (ChatCompletionResponse)
}

// ============================================================
// pass 组 - 异步工具调用接口
// ============================================================
// 异步工具调用
// - 前缀: /ai/v1
// - 认证: JWT
// - 用途: 异步执行 MCP 工具，避免长时间阻塞
//
// 使用流程:
// 1. POST /async/tool/call 提交任务，获取 task_id
// 2. GET /async/tool/result/:task_id 轮询查询状态
// 3. 状态变为 completed 时获取结果，或 failed 时获取错误信息
@server (
	prefix: ai/v1
	group:  pass
	jwt:    JwtAuth
)
service aigtw {
	@doc "异步调用 MCP 工具，提交任务后立即返回 task_id"
	@handler asyncToolCall
	post /async/tool/call (AsyncToolCallRequest) returns (AsyncToolCallResponse)

	@doc "查询异步工具调用的执行状态和结果，建议轮询间隔 1~2 秒"
	@handler asyncToolResult
	get /async/tool/result/:task_id (AsyncToolResultRequest) returns (AsyncToolResultResponse)

	@doc "分页查询异步结果列表，支持按状态、时间范围过滤，支持多字段排序"
	@handler listAsyncResults
	get /async/tool/results (ListAsyncResultsRequest) returns (ListAsyncResultsResponse)

	@doc "获取异步结果统计信息"
	@handler asyncResultStats
	get /async/tool/stats returns (AsyncResultStatsResponse)
}

// ============================================================
// 类型定义
// ============================================================
// AsyncToolCallRequest 异步工具调用请求
// 用于提交一个异步执行的 MCP 工具任务
type (
	AsyncToolCallRequest {
		// MCP 服务器名称，对应配置中的 server key
		// 例如：filesystem、github、database、mcpserver 等
		Server string `json:"server"`
		// MCP 工具名称，在对应服务器中定义的工具唯一标识
		// 例如：read_file、create_pull_request、query、test_progress 等
		Tool string `json:"tool"`
		// 工具参数字典，键为参数名，值为参数值
		// 参数类型支持：string、number、boolean、object、array
		// 具体参数由工具 schema 定义，必填参数必须提供
		// 示例：{"path": "/tmp/test.txt"} 或 {"steps": 100, "interval": 100}
		Args map[string]interface{} `json:"args"`
	}
	// AsyncToolResultRequest 查询异步结果请求
	// task_id 从 URL path 中获取
	AsyncToolResultRequest {
		TaskID string `path:"task_id"`
	}
	// AsyncToolCallResponse 异步工具调用响应
	// 提交任务后立即返回 task_id，用于后续查询
	AsyncToolCallResponse {
		// 任务唯一标识符，用于查询任务状态和结果
		// 格式：UUID 或自定义 ID
		TaskID string `json:"task_id"`
		// 任务初始状态，固定为 "pending"
		// 表示任务已提交，等待执行
		Status string `json:"status"`
	}
	// AsyncToolResultResponse 查询异步结果响应
	// 包含任务执行状态、进度、结果或错误信息
	AsyncToolResultResponse {
		// 任务标识符，与 AsyncToolCallResponse 中的 task_id 一致
		TaskID string `json:"task_id"`
		// 任务状态，有效值：
		// - pending: 任务等待执行
		// - running: 任务执行中
		// - completed: 任务已完成，可获取 result
		// - failed: 任务执行失败，可获取 error
		Status string `json:"status"`
		// 执行进度百分比，取值范围 0.0~100.0
		// 部分工具支持实时进度反馈
		// 注意：部分工具可能不支持进度，返回 0
		Progress float64 `json:"progress"`
		// 任务成功完成时的执行结果（JSON 格式字符串）
		// 仅当 status 为 "completed" 时有值
		// 可使用 JSON.parse() 解析为对象
		Result string `json:"result,omitempty"`
		// 任务失败时的错误信息
		// 仅当 status 为 "failed" 时有值
		Error string `json:"error,omitempty"`
		// 进度消息历史
		Messages []ProgressMessage `json:"messages,omitempty"`
	}
	// ProgressMessage 进度消息
	// 记录 MCP 服务器发送的所有进度通知，用于前端展示消息历史
	ProgressMessage {
		// 当前进度百分比，取值范围 0.0~100.0
		Progress float64 `json:"progress"`
		// 进度总值（参考值）
		Total float64 `json:"total"`
		// 消息内容，MCP 服务器返回的原始消息
		Message string `json:"message"`
		// 时间戳，Unix 秒级时间戳
		Time int64 `json:"time"`
	}
	// ListAsyncResultsRequest 分页查询异步结果请求
	ListAsyncResultsRequest {
		// 过滤状态：pending/completed/failed（空字符串表示全部）
		Status string `form:"status,optional"`
		// 开始时间戳（毫秒），0 表示不限制
		StartTime int64 `form:"start_time,optional"`
		// 结束时间戳（毫秒），0 表示不限制
		EndTime int64 `form:"end_time,optional"`
		// 页码，从 1 开始，默认 1
		Page int `form:"page,optional"`
		// 每页数量，默认 10，最大 100
		PageSize int `form:"page_size,optional"`
		// 排序字段：created_at/updated_at/progress
		SortField string `form:"sort_field,optional"`
		// 排序方向：asc/desc
		SortOrder string `form:"sort_order,optional"`
	}
	// ListAsyncResultsResponse 分页查询异步结果响应
	ListAsyncResultsResponse {
		// 任务列表
		Items []AsyncToolResultResponse `json:"items"`
		// 总数
		Total int64 `json:"total"`
		// 当前页
		Page int `json:"page"`
		// 每页数量
		PageSize int `json:"page_size"`
		// 总页数
		TotalPages int `json:"total_pages"`
	}
	// AsyncResultStatsResponse 异步结果统计响应
	AsyncResultStatsResponse {
		// 任务总数
		Total int64 `json:"total"`
		// 待处理任务数
		Pending int64 `json:"pending"`
		// 已完成任务数
		Completed int64 `json:"completed"`
		// 失败任务数
		Failed int64 `json:"failed"`
		// 成功率（百分比）
		SuccessRate float64 `json:"success_rate"`
	}
)

