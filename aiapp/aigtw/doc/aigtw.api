syntax = "v1"

// ============================================================
// 导入
// ============================================================
import (
	"types/openai.api"
	"types/tool.api"
	"types/solo.api"
)

// ============================================================
// 服务信息
// ============================================================
info (
	title:   "AI网关服务"
	desc:    "OpenAI 兼容 AI 网关，提供对话补全、模型列表、异步工具调用、AI Solo 智能助手等功能"
	author:  "hehanpeng"
	email:   "hehanpengyy@163.com"
	version: "v1"
)

// ============================================================
// 类型定义
// ============================================================
// ============================================================
// 模型列表接口
// ============================================================
@server (
	prefix: ai/v1
	group:  pass
	jwt:    JwtAuth
)
service aigtw {
	@doc "列出所有可用模型"
	@handler listModels
	get /models returns (ListModelsResponse)
}

// ============================================================
// 对话补全接口
// ============================================================
@server (
	prefix:  ai/v1
	group:   pass
	jwt:     JwtAuth
	timeout: 0s
	sse:     true
)
service aigtw {
	@doc "对话补全"
	@handler chatCompletions
	post /chat/completions (ChatCompletionRequest) returns (ChatCompletionResponse)
}

// ============================================================
// 异步工具调用接口
// ============================================================
@server (
	prefix: ai/v1
	group:  pass
	jwt:    JwtAuth
)
service aigtw {
	@doc "异步调用 MCP 工具，提交任务后立即返回 task_id"
	@handler asyncToolCall
	post /async/tool/call (AsyncToolCallRequest) returns (AsyncToolCallResponse)

	@doc "查询异步工具调用的执行状态和结果"
	@handler asyncToolResult
	get /async/tool/result/:task_id (AsyncToolResultRequest) returns (AsyncToolResultResponse)

	@doc "分页查询异步结果列表"
	@handler listAsyncResults
	get /async/tool/results (ListAsyncResultsRequest) returns (ListAsyncResultsResponse)

	@doc "获取异步结果统计信息"
	@handler asyncResultStats
	get /async/tool/stats returns (AsyncResultStatsResponse)
}

// ============================================================
// AI Solo 智能助手接口
// ============================================================
@server (
	prefix: solo/v1
	group:  solo
	jwt:    JwtAuth
)
service aigtw {
	@doc "列出所有 Mode (用户挑 Mode, 不再挑 Agent)"
	@handler listModes
	get /modes returns (SoloListModesResponse)

	@doc "列出 Skills 目录元数据（动态标签 / launch）"
	@handler listSkills
	get /skills returns (SoloListSkillsResponse)

	@doc "列出会话"
	@handler listSessions
	get /sessions (SoloListSessionsRequest) returns (SoloListSessionsResponse)

	@doc "创建会话"
	@handler createSession
	post /sessions (SoloCreateSessionRequest) returns (SoloCreateSessionResponse)

	@doc "获取会话"
	@handler getSession
	get /sessions/:sessionId (SoloGetSessionRequest) returns (SoloGetSessionResponse)

	@doc "删除会话"
	@handler deleteSession
	delete /sessions/:sessionId (SoloDeleteSessionRequest) returns (SoloDeleteSessionResponse)

	@doc "获取会话历史消息（一次性，供前端初次进入会话时加载）"
	@handler listMessages
	get /sessions/:sessionId/messages (SoloListMessagesRequest) returns (SoloListMessagesResponse)

	@doc "获取中断详情（页面刷新后回填 UI）"
	@handler getInterrupt
	get /interrupt/:interruptId (SoloGetInterruptRequest) returns (SoloGetInterruptResponse)
}

// ============================================================
// AI Solo 中断恢复接口（SSE）
// ============================================================
@server (
	prefix:  solo/v1
	group:   solo
	jwt:     JwtAuth
	timeout: 10m
	sse:     true
)
service aigtw {
	@doc "中断恢复（SSE 流式输出 Solo Protocol 事件）"
	@handler resume
	post /interrupt/:interruptId/resume (SoloInterruptRequest) returns (SoloInterruptResponse)
}

// ============================================================
// AI Solo 流式对话接口（SSE）
// ============================================================
@server (
	prefix:  solo/v1
	group:   solo
	jwt:     JwtAuth
	timeout: 10m
	sse:     true
)
service aigtw {
	@doc "对话（SSE 流式输出 Solo Protocol 事件）"
	@handler chat
	post /chat (SoloChatRequest) returns (SoloChatResponse)
}

