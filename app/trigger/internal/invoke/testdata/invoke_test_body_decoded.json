{
  "_说明": "invoke_test.json 中 body 字段的 base64 解码对照",

  "1_http_json_post.body": {
    "base64": "eyJuYW1lIjoiemVyby1zZXJ2aWNlIiwidmVyc2lvbiI6IjEuMC4wIn0=",
    "decoded": {"name": "zero-service", "version": "1.0.0"}
  },

  "3_http_form_urlencoded.body": {
    "base64": "eyJ1c2VybmFtZSI6ImFkbWluIiwicGFzc3dvcmQiOiIxMjM0NTYiLCJyZW1lbWJlciI6dHJ1ZX0=",
    "decoded": {"username": "admin", "password": "123456", "remember": true},
    "form_output": "password=123456&remember=true&username=admin"
  },

  "4_http_multipart_form.body": {
    "base64": "eyJmaWVsZDEiOiJ2YWx1ZTEiLCJmaWVsZDIiOiJ2YWx1ZTIifQ==",
    "decoded": {"field1": "value1", "field2": "value2"}
  },

  "5_http_nested_form.body": {
    "base64": "eyJ1c2VyIjp7Im5hbWUiOiJhZG1pbiIsImFnZSI6MjV9LCJ0YWdzIjpbImdvIiwicnVzdCJdLCJhY3RpdmUiOnRydWUsIm1ldGEiOm51bGx9",
    "decoded": {"user": {"name": "admin", "age": 25}, "tags": ["go", "rust"], "active": true, "meta": null},
    "form_output": "active=true&tags=go&tags=rust&user.age=25&user.name=admin",
    "_note": "meta=null 被自动过滤; user 嵌套对象被扁平化为 user.name/user.age; tags 数组展开为多值"
  },

  "6_http_put.body": {
    "base64": "eyJpZCI6MSwic3RhdHVzIjoidXBkYXRlZCJ9",
    "decoded": {"id": 1, "status": "updated"}
  },

  "8_mix_http.body": {
    "base64": "eyJzb3VyY2UiOiJtaXhlZC10ZXN0In0=",
    "decoded": {"source": "mixed-test"}
  },

  "12_json_post.body": {
    "base64": "eyJoZWxsbyI6IndvcmxkIn0=",
    "decoded": {"hello": "world"}
  },

  "13_form_post.body": {
    "base64": "eyJrZXkxIjoidmFsdWUxIiwia2V5MiI6InZhbHVlMiJ9",
    "decoded": {"key1": "value1", "key2": "value2"},
    "form_output": "key1=value1&key2=value2"
  }
}
